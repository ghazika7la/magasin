{
  "version": 2,
  "name": "magasin-jeux",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/docs/index.html"
    },
    {
      "src": "/jeux.html",
      "dest": "/docs/jeux.html"
    },
    {
      "src": "/styles-5INURTSO.css",
      "dest": "/docs/styles-5INURTSO.css"
    },
    {
      "src": "/logo-icon.svg",
      "dest": "/docs/logo-icon.svg"
    }
  ]
}
